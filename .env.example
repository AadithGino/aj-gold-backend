# Server
PORT=8000
NODE_ENV=development

# MongoDB — transactions require a replica set (Atlas or local replica set)
MONGO_URI=mongodb://127.0.0.1:27017/ajgold_dev?replicaSet=rs0

# Allow npm run reset:demo (requires dev/demo/test in database name)
ALLOW_DATABASE_RESET=false

# Auth
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

# CORS (comma-separated). Leave empty to allow all origins (including React Native without Origin header).
CORS_ORIGINS=

# Request body limit
BODY_SIZE_LIMIT=100kb

# Login rate limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=20

# Seed scripts (required for seed:admin — never use defaults in production)
DEFAULT_ADMIN_PHONE=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Admin

# Set to true only when intentionally seeding production
SEED_ALLOW_PRODUCTION=false

# Test database (optional — mongodb-memory-server used by default in npm test)
TEST_MONGO_URI=
